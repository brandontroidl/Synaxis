/* ==========================================================================
 * Synaxis 2.2.0 — Example Configuration
 * ==========================================================================
 * Copyright (c) Cathexis Development
 *
 * MINIMUM changes required:
 *   1. uplinks — address, port, password (must match ircd Connect block)
 *   2. server  — hostname, numeric (must differ from ircd and other services)
 *   3. server  — host_hiding_key1/2/3 (must match ircd HOST_HIDING_KEY1/2/3)
 *   4. server  — admin account name
 * ========================================================================== */

"uplinks" {
    "irc.example.org" {
        "address"       "127.0.0.1";
        "port"          "4401";
        "password"      "$LINK_PASSWORD";
        "their_password" "$LINK_PASSWORD";
        "enabled"       "1";
        "max_tries"     "10";
        "interval"      "60";
        "ssl"           "1";
    };
};

"server" {
    "hostname"      "services.example.org";
    "description"   "Network Services";
    "network"       "ExampleNet";
    "hidden_host"   "Users.ExampleNet";
    "numeric"       "2";
    "max_users"     "256";
    "admin"         "admin";

    /* Must match ircd HOST_HIDING_KEY1/2/3 */
    "host_hiding_key1" "CHANGEME";
    "host_hiding_key2" "CHANGEME";
    "host_hiding_key3" "CHANGEME";
    "host_hiding_style" "3";
    "host_hiding_prefix" "ExampleNet";
    "s2s_hmac"      "1";
    "db_encryption_key" "CHANGEME_openssl_rand_hex_32";
};

"services" {
    "nickserv" {
        "nick"          "NickServ";
        "modes"         "+iok";
        "description"   "Account Services";
        "default_hostmask" "1";
        "password_min_length" "6";
        "default_style" "n";
        "nicks_per_handle" "4";
        "handles_per_email" "1";
        "email_required" "0";
        "email_enabled" "0";
        "max_logins" "3";
        "handle_expire_frequency" "1d";
        "handle_expire_delay" "30d";
        "disable_nicks" "0";
        "nick_expire_frequency" "1d";
        "nick_expire_delay" "30d";
        "handle_ts_mode" "1";
        "sasl_enabled" "1";
        "loc_auth"      "1";
    };

    "chanserv" {
        "nick"          "ChanServ";
        "modes"         "+iok";
        "description"   "Channel Services";
        "trigger"       ".";
        "chan_expire_frequency" "3d";
        "chan_expire_delay"     "30d";
        "max_owned"     "5";
        "default_modes" "+tn";
        "max_chan_bans"  "100";
        "nodelete_level" "500";
        "protect_cservice" "1";
        "greeting_length" "200";
    };

    "opserv" {
        "nick"          "OperServ";
        "modes"         "+iok";
        "description"   "Operator Services";
        "privileged"    "1";
        "debug_channel"       "#opers";
        "debug_channel_modes" "+tinms";
        "alert_channel"       "#opers";
        "alert_channel_modes" "+tinms";
        "staff_auth_channel"  "#opers";
        "staff_auth_channel_modes" "+tinms";
    };

    "global" {
        "nick"          "Global";
        "modes"         "+iok";
        "description"   "Global Announcements";
    };

    "spamserv" {
        "nick"          "SpamServ";
        "modes"         "+iok";
        "description"   "Anti-Spam Service";
        "debug_channel" "#opers";
    };
};

"modules" {
    "helpserv" {
        "bot_nick"       "HelpServ";
        "description"    "Help Queue Service";
        "support_channel" "#help";
        "support_channel_modes" "+tn";
    };

    "hostserv" {
        "bot"           "HostServ";
        "description"   "Virtual Host Service";
        "modes"         "+iok";
    };

    "botserv" {
        "bot"           "BotServ";
        "description"   "Channel Bot Service";
        "modes"         "+iok";
    };

    "memoserv" {
        "bot"           "MemoServ";
        "description"   "Memo Service";
        "max_memos"     "30";
        "message_expiry" "30d";
    };

    "groupserv" {
        "bot"           "GroupServ";
        "description"   "Account Group Management";
        "modes"         "+iok";
    };

    "chanfix" {
        "bot"           "ChanFix";
        "description"   "Automated Channel Recovery";
        "modes"         "+iok";
    };

    "infoserv" {
        "bot"           "InfoServ";
        "description"   "Network Announcements";
        "modes"         "+iok";
    };

    "blacklist" {
        "dnsbl_zone_1" "dnsbl.dronebl.org";
        "dnsbl_zone_2" "rbl.efnetrbl.org";
        "gline_duration" "1h";
    };

    "sockcheck" {
        "max_sockets"   "64";
        "max_read"      "1024";
        "timeout"       "30";
        "address"       "0.0.0.0";
    };

    "track" {
        "bot"           "OperServ";
        "channel"       "#opers";
        "channel_modes" "+sntim";
    };

    "snoop" {
        "bot"           "OperServ";
        "channel"       "#opers";
        "channel_modes" "+sntim";
    };

    "python" {
        "scripts_dir" "/path/to/services/share/x3";
        "main_module" "modpython";
    };

    "webtv" {
    };
};

"mail" {
    "enable"        "0";
};

"dbs" {
    "ChanServ" { "mondo_section" "ChanServ"; };
    "gline"    { "mondo_section" "gline"; };
    "shun"     { "mondo_section" "shun"; };
    "Global"   { "mondo_section" "Global"; };
    "NickServ" { "mondo_section" "NickServ"; };
    "SpamServ" { "mondo_section" "SpamServ"; };
    "HelpServ" { "mondo_section" "HelpServ"; };
    "HostServ" { "mondo_section" "HostServ"; };
    "BotServ"  { "mondo_section" "BotServ"; };
    "MemoServ" { "mondo_section" "MemoServ"; };
    "GroupServ" { "mondo_section" "GroupServ"; };
    "ChanFix" { "mondo_section" "ChanFix"; };
    "InfoServ" { "mondo_section" "InfoServ"; };
    "OperServ" { "mondo_section" "OperServ"; };
    "write_frequency" "5m";
    "mondo_file"    "x3.db";
};

"logs" {
    "x3" {
        "*"             "file:x3.log";
        "*.error"       "file:error.log";
    };
};

"<index>" ("$bDatabase System$b",
           " ",
           "  WRITE     Force database write",
           "  WRITEALL  Write all databases",
           " ",
           "Synaxis databases are written automatically on a schedule.",
           "Use WRITE/WRITEALL to force an immediate save.");
